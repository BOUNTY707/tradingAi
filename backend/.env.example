# Database — Neon PostgreSQL
# Neon Dashboard → Connection Details → Connection string (Pooled connection)
# "?sslmode=require" qism majburiy
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# JWT
JWT_SECRET="your-super-secret-jwt-key-minimum-256-bits"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="your-refresh-secret-key-minimum-256-bits"

# Redis (ixtiyoriy)
REDIS_URL="redis://default:PASSWORD@HOST:PORT"

# Server
PORT=4000
NODE_ENV=production

# Frontend URL (Vercel URL)
FRONTEND_URL="https://your-app.vercel.app"

# Groq AI
GROQ_API_KEY="gsk_your-groq-api-key"

# Google OAuth (ixtiyoriy)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
